generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shipment {
  id                      String            @id @default(uuid())
  reference               String
  exporter                String
  importer                String
  commercialInvoiceNumber String
  invoiceValue            Decimal           @db.Decimal(12, 2)
  currencyCode            String
  goodsDescription        String
  hsCode                  String
  countryCode             String
  grossWeightKg           Decimal           @db.Decimal(12, 2)
  netWeightKg             Decimal           @db.Decimal(12, 2)
  numberOfPackages        Int
  containerNumber         String
  billOfLadingNumber      String
  packagingType           String
  ispm15Certified         Boolean?
  arrivalDate             DateTime
  status                  ShipmentStatus    @default(DRAFT)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  currency                IsoCurrency       @relation(fields: [currencyCode], references: [code])
  country                 IsoCountry        @relation(fields: [countryCode], references: [code])
  issues                  ValidationIssue[]
  auditLogs               AuditLog[]
}

model ValidationIssue {
  id              String   @id @default(uuid())
  shipmentId      String
  issueType       String
  severity        Severity
  fieldInvolved   String
  explanation     String
  suggestedAction String
  isResolved      Boolean  @default(false)
  createdAt       DateTime @default(now())

  shipment        Shipment @relation(fields: [shipmentId], references: [id])
}

model AuditLog {
  id         String      @id @default(uuid())
  shipmentId String
  timestamp  DateTime    @default(now())
  action     AuditAction
  actor      String
  details    Json

  shipment   Shipment    @relation(fields: [shipmentId], references: [id])
}

model IsoCountry {
  code      String     @id
  name      String
  shipments Shipment[]
}

model IsoCurrency {
  code      String     @id
  name      String
  shipments Shipment[]
}

enum ShipmentStatus {
  DRAFT
  PENDING_REVIEW
  READY
  ISSUES_FOUND
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  SHIPMENT_CREATED
  DOCUMENT_INGESTED
  FIELD_UPDATED
  VALIDATION_RUN
  READINESS_REPORT_GENERATED
  STATUS_CHANGED
}
